# Application
APP_ENV=development
APP_SECRET_KEY=change-me-in-production
APP_DEBUG=true

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=taskhub
DB_USER=taskhub
DB_PASSWORD=secret

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# JWT
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=HS256

# Mail (SMTP)
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=no-reply@example.com
MAIL_PASSWORD=secret
MAIL_FROM=TaskHub <no-reply@example.com>
