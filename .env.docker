# Application
APP_ENV=development
APP_SECRET_KEY=change-me-in-production
APP_DEBUG=true

# Database 
DATABASE_URL=postgresql+asyncpg://postgres:mysecretpassword@db:5432/taskhub_db

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# JWT
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=HS256

# Mail (SMTP)
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=no-reply@example.com
MAIL_PASSWORD=secret
MAIL_FROM=TaskHub <no-reply@example.com>